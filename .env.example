# ─── Laravel Core ─────────────────────────────────────────────
APP_NAME="Desa Karangtalun API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta

FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=desa_karangtalun
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache / Session / Queue ──────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

# ─── Cloudflare Turnstile ─────────────────────────────────────
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=

# ─── OTP / Password Reset ────────────────────────────────────
OTP_CHANNEL=log
OTP_DEBUG=true
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
RESET_TOKEN_EXPIRY_MINUTES=15

# ─── WhatsApp / SMS (production) ─────────────────────────────
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=
# SMS_API_URL=
# SMS_API_TOKEN=

# ─── Sanctum / CORS ──────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000

# ══════════════════════════════════════════════════════════════
# PRODUCTION SETTINGS (uncomment/change when deploying)
# ══════════════════════════════════════════════════════════════
# APP_ENV=production
# APP_DEBUG=false
# CACHE_STORE=file  (atau redis)
# TURNSTILE_ENABLED=true
# TURNSTILE_SECRET_KEY=secret_asli_dari_cloudflare
# OTP_CHANNEL=whatsapp
# OTP_DEBUG=false
# WHATSAPP_API_URL=https://api.vendor-whatsapp.com/send
# WHATSAPP_API_TOKEN=token_asli
